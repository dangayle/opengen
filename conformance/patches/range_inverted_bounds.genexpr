// wrap(1.25, 1, 0): inverted → normalized to wrap(1.25, 0, 1) = 0.25
// fold(1.25, 1, 0): inverted → normalized to fold(1.25, 0, 1) = 0.75
out1 = clip(0.5, 1, 0);
out2 = wrap(1.25, 1, 0);
out3 = fold(1.25, 1, 0);
