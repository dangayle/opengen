// slide_step.genexpr
// Step response of slide (logarithmic smoother).
// Step from 0 to 1 at sample 1 (sample 0 is 0).
// Slide time constants: up=4, down=4 samples.
// out1 = slewed step (asymptotic approach to 1.0).
// gen~ compat: declared History + reads-before-write (see history_counter).
History h(0);
step = switch(gt(h, 0), 1, 0);
out1 = slide(step, 4, 4);
h = h + 1;
